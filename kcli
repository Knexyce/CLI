def install_pip():
    import subprocess
    import sys
    import os
    import urllib.request
    try:
        subprocess.check_call([sys.executable, '-m', 'pip', '--version'])
        print("PIP is already installed.")
        return
    except subprocess.CalledProcessError:
        print("PIP is not installed. Installing...")
    try:
        os.system("sudo apt-get -y update")
        os.system("sudo apt-get install -y python3-pip")
        os.system("sudo apt-get -y dist-upgrade")
        os.system("sudo apt-get -y full upgrade")
        subprocess.check_call([sys.executable, '-m', 'pip', '--version'])
        print("PIP has been installed successfully using 'apt-get'.")
        return
    except subprocess.CalledProcessError:
        print("System package installation failed. Attempting ensurepip...")
    try:
        subprocess.check_call([sys.executable, '-m', 'ensurepip'])
        print("PIP has been installed successfully using 'ensurepip'.")
        return
    except subprocess.CalledProcessError:
        print("'ensurepip' failed. Attempting to install PIP via 'get-pip.py'...")
    try:
        url = "https://bootstrap.pypa.io/get-pip.py"
        get_pip_script = "get-pip.py"
        urllib.request.urlretrieve(url, get_pip_script)
        print("Downloaded get-pip.py.")
